bel":"text","block_content":"4. Chefer 方法","block_bbox":[764,275,926,303],"block_id":7,"block_order":7,"group_id":7,"block_polygon_points":[[764.0,275.0],[926.0,275.0],[926.0,303.0],[764.0,303.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1116_130_1155_167.jpg\" alt=\"Image\" width=\"2%\" /></div>\n","block_bbox":[1116,130,1155,167],"block_id":8,"group_id":8,"block_polygon_points":[[1116.0,130.0],[1154.0,130.0],[1154.0,166.0],[1116.0,166.0]]},{"block_label":"paragraph_title","block_content":"### 核心解释目标","block_bbox":[1166,133,1326,164],"block_id":9,"block_order":8,"group_id":9,"block_polygon_points":[[1166.0,133.0],[1326.0,133.0],[1326.0,164.0],[1166.0,164.0]]},{"block_label":"text","block_content":"解释单个样本为何得到当前预测","block_bbox":[1100,180,1375,206],"block_id":10,"block_order":9,"group_id":10,"block_polygon_points":[[1100.0,180.0],[1375.0,180.0],[1375.0,206.0],[1100.0,206.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1059_220_1089_249.jpg\" alt=\"Image\" width=\"2%\" /></div>\n","block_bbox":[1059,220,1089,249],"block_id":11,"group_id":11,"block_polygon_points":[[1059.0,220.0],[1088.0,220.0],[1088.0,248.0],[1059.0,248.0]]},{"block_label":"text","block_content":"识别关键特征 / token / patch","block_bbox":[1101,222,1374,249],"block_id":12,"block_order":10,"group_id":12,"block_polygon_points":[[1101.0,222.0],[1374.0,222.0],[1374.0,249.0],[1101.0,249.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1056_260_1090_294.jpg\" alt=\"Image\" width=\"2%\" /></div>\n","block_bbox":[1056,260,1090,294],"block_id":13,"group_id":13,"block_polygon_points":[[1056.0,260.0],[1089.0,260.0],[1089.0,293.0],[1056.0,293.0]]},{"block_label":"text","block_content":"帮助分析模型决策依据与局限","block_bbox":[1100,263,1361,288],"block_id":14,"block_order":11,"group_id":14,"block_polygon_points":[[1100.0,263.0],[1361.0,263.0],[1361.0,288.0],[1100.0,288.0]]},{"block_label":"paragraph_title","block_content":"## 1. LIME","block_bbox":[39,330,131,355],"block_id":15,"block_order":12,"group_id":15,"block_polygon_points":[[39.0,330.0],[130.0,330.0],[130.0,354.0],[39.0,354.0]]},{"block_label":"paragraph_title","block_content":"##### 局部扰动解释 / 模型无关","block_bbox":[185,332,381,354],"block_id":16,"block_order":13,"group_id":16,"block_polygon_points":[[185.0,332.0],[380.0,332.0],[380.0,353.0],[185.0,353.0]]},{"block_label":"text","block_content":"- 核心思想：在目标样本附近生成扰动样本，用简单线性模型近似黑箱模型的局部行为。","block_bbox":[38,366,366,408],"block_id":17,"block_order":14,"group_id":17,"block_polygon_points":[[38.0,366.0],[366.0,366.0],[366.0,408.0],[38.0,408.0]]},{"block_label":"text","block_content":"• 典型公式： $ \\xi(x)=\\arg\\min_{g\\in G}L(f,g,\\pi_{x})+\\Omega(g) $","block_bbox":[37,416,406,439],"block_id":18,"block_order":15,"group_id":18,"block_polygon_points":[[37.0,416.0],[406.0,416.0],[406.0,439.0],[37.0,439.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_456_332_706_470.jpg\" alt=\"Image\" width=\"16%\" /></div>\n","block_bbox":[456,332,706,470],"block_id":19,"group_id":19,"block_polygon_points":[[456.0,332.0],[706.0,332.0],[706.0,470.0],[456.0,470.0]]},{"block_label":"text","block_content":"• 优点：直观、灵活、实现简单。","block_bbox":[37,446,278,467],"block_id":20,"block_order":16,"group_id":20,"block_polygon_points":[[37.0,446.0],[277.0,446.0],[277.0,466.0],[37.0,466.0]]},{"block_label":"text","block_content":"· 局限：对采样、核函数、扰动方式敏感，稳定性较弱。","block_bbox":[37,473,437,494],"block_id":21,"block_order":17,"group_id":21,"block_polygon_points":[[37.0,473.0],[437.0,473.0],[437.0,494.0],[37.0,494.0]]},{"block_label":"text","block_content":"· 适用对象：文本、图像、表格的局部解释。","block_bbox":[37,500,358,521],"block_id":22,"block_order":18,"group_id":22,"block_polygon_points":[[37.0,500.0],[357.0,500.0],[357.0,520.0],[37.0,520.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_469_483_491_501.jpg\" alt=\"Image\" width=\"1%\" /></div>\n","block_bbox":[469,483,491,501],"block_id":23,"group_id":23,"block_polygon_points":[[469.0,483.0],[490.0,483.0],[490.0,500.0],[469.0,500.0]]},{"block_label":"text","block_content":"扰动样本\n\n×（原始样本）","block_bbox":[491,483,548,500],"block_id":24,"block_order":19,"group_id":24,"block_polygon_points":[[491.0,483.0],[547.0,483.0],[547.0,499.0],[491.0,499.0]]},{"block_label":"text","block_content":"","block_bbox":[492,508,568,525],"block_id":25,"block_order":20,"group_id":24,"block_polygon_points":[[492.0,508.0],[567.0,508.0],[567.0,524.0],[492.0,524.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_594_482_615_502.jpg\" alt=\"Image\" width=\"1%\" /></div>\n","block_bbox":[594,482,615,502],"block_id":26,"group_id":26,"block_polygon_points":[[594.0,482.0],[614.0,482.0],[614.0,501.0],[594.0,501.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_467_505_492_526.jpg\" alt=\"Image\" width=\"1%\" /></div>\n","block_bbox":[467,505,492,526],"block_id":27,"group_id":27,"block_polygon_points":[[467.0,505.0],[491.0,505.0],[491.0,525.0],[467.0,525.0]]},{"block_label":"text","block_content":"局部邻城","block_bbox":[623,484,674,500],"block_id":28,"block_order":21,"group_id":28,"block_polygon_points":[[623.0,484.0],[673.0,484.0],[673.0,499.0],[623.0,499.0]]},{"block_label":"text","block_content":"局部线性拟合","block_bbox":[622,508,699,526],"block_id":29,"block_order":22,"group_id":29,"block_polygon_points":[[622.0,508.0],[698.0,508.0],[698.0,525.0],[622.0,525.0]]},{"block_label":"paragraph_title","block_content":"## 2. SHAP","block_bbox":[759,330,856,356],"block_id":30,"block_order":23,"group_id":30,"block_polygon_points":[[759.0,330.0],[856.0,330.0],[856.0,356.0],[759.0,356.0]]},{"block_label":"paragraph_title","block_content":"##### 博弈论归因 / 加性特征贡献","block_bbox":[891,332,1111,354],"block_id":31,"block_order":24,"group_id":31,"block_polygon_points":[[891.0,332.0],[1111.0,332.0],[1111.0,354.0],[891.0,354.0]]},{"block_label":"text","block_content":"- 核心思想：把特征看作合作博弈的参与者，用 Shapley value 分配每个特征的平均边际贡献。","block_bbox":[756,366,1150,410],"block_id":32,"block_order":25,"group_id":32,"block_polygon_points":[[756.0,366.0],[1150.0,366.0],[1150.0,410.0],[756.0,410.0]]},{"block_label":"text","block_content":"• 典型公式： $ f(x)=\\phi_{0}+\\sum\\phi_{i} $","block_bbox":[756,418,998,445],"block_id":33,"block_order":26,"group_id":33,"block_polygon_points":[[756.0,418.0],[998.0,418.0],[998.0,445.0],[756.0,445.0]]},{"block_label":"text","block_content":"• 优点：理论基础强，满足局部准确性、一致性、缺失性。","block_bbox":[755,452,1168,473],"block_id":34,"block_order":27,"group_id":34,"block_polygon_points":[[755.0,452.0],[1168.0,452.0],[1168.0,473.0],[755.0,473.0]]},{"block_label":"text","block_content":"· 局限：计算成本高，常需近似。","block_bbox":[756,479,993,499],"block_id":35,"block_order":28,"group_id":35,"block_polygon_points":[[756.0,479.0],[992.0,479.0],[992.0,498.0],[756.0,498.0]]},{"block_label":"text","block_content":"· 适用对象：表格、文本、树模型与深度模型归因。","block_bbox":[755,505,1121,526],"block_id":36,"block_order":29,"group_id":36,"block_polygon_points":[[755.0,505.0],[1120.0,505.0],[1120.0,525.0],[755.0,525.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1189_338_1448_504.jpg\" alt=\"Image\" width=\"17%\" /></div>\n","block_bbox":[1189,338,1448,504],"block_id":37,"group_id":37,"block_polygon_points":[[1189.0,338.0],[1448.0,338.0],[1448.0,504.0],[1189.0,504.0]]},{"block_label":"paragraph_title","block_content":"##### 逐层相关性传播 / 白盒解释","block_bbox":[181,561,390,583],"block_id":38,"block_order":30,"group_id":38,"block_polygon_points":[[181.0,561.0],[389.0,561.0],[389.0,582.0],[181.0,582.0]]},{"block_label":"text","block_content":"- 核心思想：从目标输出开始，将 relevance 逐层向输入分配，得到各输入特征的相关性分数。","block_bbox":[38,596,399,638],"block_id":39,"block_order":31,"group_id":39,"block_polygon_points":[[38.0,596.0],[399.0,596.0],[399.0,638.0],[38.0,638.0]]},{"block_label":"text","block_content":"- 关键性质：相关性守恒  $ \\Sigma R^{(l)} = \\Sigma R^{(l+1)} $","block_bbox":[37,643,351,666],"block_id":40,"block_order":32,"group_id":40,"block_polygon_points":[[37.0,643.0],[351.0,643.0],[351.0,666.0],[37.0,666.0]]},{"block_label":"text","block_content":"· 局限：传统 LRP 更适合 CNN / ReLU；在 Transformer 中会遇到残差、矩阵乘法和正负激活问题。","block_bbox":[37,696,428,736],"block_id":41,"block_order":33,"group_id":41,"block_polygon_points":[[37.0,696.0],[428.0,696.0],[428.0,736.0],[37.0,736.0]]},{"block_label":"text","block_content":"• 优点：能利用网络内部结构，比只看 attention 更深入。","block_bbox":[37,670,427,691],"block_id":42,"block_order":34,"group_id":42,"block_polygon_points":[[37.0,670.0],[426.0,670.0],[426.0,690.0],[37.0,690.0]]},{"block_label":"text","block_content":"· 适用对象：CNN 及可访问内部结构的神经网络。\n\n输出层\n\n(高层)","block_bbox":[36,741,391,762],"block_id":43,"block_order":35,"group_id":43,"block_polygon_points":[[36.0,741.0],[390.0,741.0],[390.0,761.0],[36.0,761.0]]},{"block_label":"text","block_content":"","block_bbox":[447,568,492,604],"block_id":44,"block_order":36,"group_id":43,"block_polygon_points":[[447.0,568.0],[492.0,568.0],[492.0,604.0],[447.0,604.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_444_563_709_763.jpg\" alt=\"Image\" width=\"17%\" /></div>\n","block_bbox":[444,563,709,763],"block_id":45,"group_id":45,"block_polygon_points":[[444,569],[444,720],[452,731],[466,731],[459,726],[482,762],[708,762],[708,563],[475,563]]},{"block_label":"text","block_content":"----→ relevance 传播","block_bbox":[499,734,654,752],"block_id":46,"block_order":37,"group_id":46,"block_polygon_points":[[499,739],[499,747],[536,751],[646,751],[653,747],[653,734],[514,734]]},{"block_label":"paragraph_title","block_content":"## 4. Chefer 方法","block_bbox":[752,559,913,586],"block_id":47,"block_order":38,"group_id":47,"block_polygon_points":[[752.0,559.0],[913.0,559.0],[913.0,586.0],[752.0,586.0]]},{"block_label":"paragraph_title","block_content":"## Transformer 专用解释 / attention+gradient+relevance","block_bbox":[927,559,1120,596],"block_id":48,"block_order":39,"group_id":48,"block_polygon_points":[[927.0,559.0],[1120.0,559.0],[1120.0,596.0],[927.0,596.0]]},{"block_label":"text","block_content":"- 核心思想：融合 attention、目标类别梯度与 relevance，在多层间传播，得到类别相关的 token / patch 重要性。","block_bbox":[751,603,1124,640],"block_id":49,"block_order":40,"group_id":49,"block_polygon_points":[[751.0,603.0],[1124.0,603.0],[1124.0,640.0],[751.0,640.0]]},{"block_label":"text","block_content":"• 典型公式： $ \\vec{A}^{(b)} = I + E_h \\left( \\nabla A^{(b)} \\odot R^{(n_b)} \\right)^+ $","block_bbox":[749,644,1079,667],"block_id":50,"block_order":41,"group_id":50,"block_polygon_points":[[749.0,644.0],[1079.0,644.0],[1079.0,667.0],[749.0,667.0]]},{"block_label":"text","block_content":"• 优点：适配 Transformer 结构，类别相关性强，优于 raw attention / rollout。","block_bbox":[750,673,1080,712],"block_id":51,"block_order":42,"group_id":51,"block_polygon_points":[[750.0,673.0],[1080.0,673.0],[1080.0,712.0],[750.0,712.0]]},{"block_label":"text","block_content":"· 局限：实现复杂，需要访问 attention、梯度和中间层。","block_bbox":[749,717,1134,737],"block_id":52,"block_order":43,"group_id":52,"block_polygon_points":[[748.9998779296875,716.9999389648438],[1132.9998779296875,716.9999389648438],[1132.9998779296875,735.9999389648438],[748.9998779296875,735.9999389648438]]},{"block_label":"text","block_content":"· 适用对象：BERT、ViT 等 Transformer 模型解释。\n\n层 L","block_bbox":[749,742,1118,763],"block_id":53,"block_order":44,"group_id":53,"block_polygon_points":[[757.0,742.0],[1117.0,742.0],[1117.0,762.0],[757.0,762.0]]},{"block_label":"text","block_content":"","block_bbox":[1146,701,1173,719],"block_id":54,"block_order":45,"group_id":53,"block_polygon_points":[[1146,701],[1146,718],[1172,718],[1172,701]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1148_595_1427_750.jpg\" alt=\"Image\" width=\"18%\" /></div>\n","block_bbox":[1148,595,1427,750],"block_id":55,"group_id":55,"block_polygon_points":[[1148.0,595.0],[1427.0,595.0],[1427.0,750.0],[1148.0,750.0]]},{"block_label":"paragraph_title","block_content":"##### → 方法对比","block_bbox":[31,781,141,804],"block_id":56,"block_order":46,"group_id":56,"block_polygon_points":[[31.0,781.0],[139.99998474121094,781.0],[139.99998474121094,803.0],[31.0,803.0]]},{"block_label":"table","block_content":"\n<table border=1 style='margin: auto; word-wrap: break-word;'><tr><td style='text-align: center; word-wrap: break-word;'>方法</td><td style='text-align: center; word-wrap: break-word;'>是否模型无关</td><td style='text-align: center; word-wrap: break-word;'>是否类别相关</td><td style='text-align: center; word-wrap: break-word;'>核心优势</td><td style='text-align: center; word-wrap: break-word;'>主要局限</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>LIME</td><td style='text-align: center; word-wrap: break-word;'>是</td><td style='text-align: center; word-wrap: break-word;'>可针对单样本解释</td><td style='text-align: center; word-wrap: break-word;'>直观、灵活、容易实现</td><td style='text-align: center; word-wrap: break-word;'>对扰动采样敏感</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>SHAP</td><td style='text-align: center; word-wrap: break-word;'>可模型无关或模型特定</td><td style='text-align: center; word-wrap: break-word;'>是</td><td style='text-align: center; word-wrap: break-word;'>理论性质强、贡献可加和</td><td style='text-align: center; word-wrap: break-word;'>计算开销大</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>LRP</td><td style='text-align: center; word-wrap: break-word;'>否</td><td style='text-align: center; word-wrap: break-word;'>是</td><td style='text-align: center; word-wrap: break-word;'>relevance 逐层传播、可利用内部结构</td><td style='text-align: center; word-wrap: break-word;'>迁移到 Transformer 较困难</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>Chefer 方法</td><td style='text-align: center; word-wrap: break-word;'>否</td><td style='text-align: center; word-wrap: break-word;'>是</td><td style='text-align: center; word-wrap: break-word;'>更适合 Transformer，类别区分能力强</td><td style='text-align: center; word-wrap: break-word;'>需要 attention、gradient、relevance</td></tr></table>","block_bbox":[28,812,1037,978],"block_id":57,"group_id":57,"block_polygon_points":[[28.0,812.0],[1037.0,812.0],[1037.0,978.0],[28.0,978.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1091_799_1137_837.jpg\" alt=\"Image\" width=\"3%\" /></div>\n","block_bbox":[1091,799,1137,837],"block_id":58,"group_id":58,"block_polygon_points":[[1091.0,804.0],[1136.0,804.0],[1136.0,836.0],[1091.0,836.0]]},{"block_label":"paragraph_title","block_content":"### 关系梳理","block_bbox":[1149,805,1255,835],"block_id":59,"block_order":47,"group_id":59,"block_polygon_points":[[1149.0,805.0],[1255.0,805.0],[1255.0,835.0],[1149.0,835.0]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1084_847_1118_881.jpg\" alt=\"Image\" width=\"2%\" /></div>\n","block_bbox":[1084,847,1118,881],"block_id":60,"group_id":60,"block_polygon_points":[[1084.0,847.0],[1117.0,847.0],[1117.0,880.0],[1084.0,880.0]]},{"block_label":"text","block_content":"LIME 与 SHAP: 偏输入扰动 / 特征归因","block_bbox":[1108,851,1420,877],"block_id":61,"block_order":48,"group_id":61,"block_polygon_points":[[1124,851],[1124,876],[1419,876],[1419,857],[1389,851]]},{"block_label":"image","block_content":"<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1085_892_1118_926.jpg\" alt=\"Image\" width=\"2%\" /></div>\n","block_bbox":[1085,892,1118,926],"block_id":62,"group_id":62,"block_polygon_points":[[1085.0,892.0],[1117.0,892.0],[1117.0,921.0],[1085.0,921.0]]},{"block_label":"text","block_content":"LRP: 偏层间 relevance 传播","block_bbox":[1126,898,1344,922],"block_id":63,"block_ord